<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Adrian Studio | Hemsidor för restauranger</title>
    <meta
      name="description"
      content="Portfolio för moderna företagshemsidor med fokus på restauranger, menyer, bokningar och lokala varumärken."
    />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://images.pexels.com" />
    <style>
      :root {
        --ink: #181614;
        --muted: #67615a;
        --paper: #fffaf1;
        --surface: #ffffff;
        --line: #e7ded0;
        --accent: #b83224;
        --accent-dark: #711e18;
        --sage: #405c4b;
        --gold: #c88f2d;
        --shadow: 0 22px 60px rgba(43, 31, 22, 0.16);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background: var(--paper);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      img {
        display: block;
        max-width: 100%;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .nav {
        position: fixed;
        z-index: 20;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 18px clamp(18px, 5vw, 64px);
        background: rgba(255, 250, 241, 0.86);
        border-bottom: 1px solid rgba(231, 222, 208, 0.75);
        backdrop-filter: blur(18px);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
      }

      .brand-mark {
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        color: #fff;
        background: var(--accent);
        border-radius: 8px;
        font-weight: 900;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: clamp(12px, 3vw, 28px);
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 650;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      .nav-cta,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 18px;
        color: #fff;
        background: var(--ink);
        border: 0;
        border-radius: 8px;
        font-weight: 800;
        box-shadow: 0 10px 25px rgba(24, 22, 20, 0.16);
      }

      .button.secondary {
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--line);
        box-shadow: none;
      }

      .hero {
        min-height: 92vh;
        display: grid;
        align-items: end;
        padding: 132px clamp(18px, 5vw, 64px) 40px;
        color: #fff;
        background:
          linear-gradient(90deg, rgba(21, 14, 9, 0.86), rgba(21, 14, 9, 0.42) 58%, rgba(21, 14, 9, 0.12)),
          url("https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=2200&q=82")
            center / cover;
      }

      .proof-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: var(--surface);
      }

      .proof-strip div {
        padding: 24px clamp(18px, 4vw, 48px);
        border-right: 1px solid var(--line);
      }

      .proof-strip div:last-child {
        border-right: 0;
      }

      .proof-strip strong {
        display: block;
        margin-bottom: 6px;
        color: var(--accent);
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
      }

      .proof-strip span {
        color: var(--muted);
        line-height: 1.5;
      }

      .hero-grid {
        width: min(1180px, 100%);
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: clamp(28px, 5vw, 72px);
        align-items: end;
      }

      .eyebrow {
        margin: 0 0 16px;
        color: #f5c566;
        font-size: 0.88rem;
        font-weight: 850;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        max-width: 850px;
        margin-bottom: 22px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(3rem, 8vw, 7.8rem);
        line-height: 0.9;
        font-weight: 800;
      }

      .hero-copy {
        max-width: 650px;
        margin-bottom: 28px;
        color: rgba(255, 255, 255, 0.86);
        font-size: clamp(1.05rem, 2vw, 1.25rem);
        line-height: 1.65;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .hero-actions .secondary {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.34);
      }

      .quick-panel {
        display: grid;
        gap: 18px;
        padding: 22px;
        background: rgba(255, 250, 241, 0.95);
        color: var(--ink);
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .metric {
        display: grid;
        grid-template-columns: 66px 1fr;
        gap: 14px;
        align-items: center;
      }

      .metric strong {
        color: var(--accent);
        font-family: Georgia, "Times New Roman", serif;
        font-size: 2rem;
      }

      .metric span {
        color: var(--muted);
        line-height: 1.45;
      }

      .section {
        padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px);
      }

      .section-inner {
        width: min(1180px, 100%);
        margin: 0 auto;
      }

      .section-head {
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) minmax(260px, 0.46fr);
        gap: 32px;
        align-items: end;
        margin-bottom: 32px;
      }

      h2 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.1rem, 5vw, 4.5rem);
        line-height: 1;
      }

      .lead {
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.7;
      }

      .why-grid {
        display: grid;
        grid-template-columns: 0.75fr 1.25fr;
        gap: clamp(28px, 5vw, 64px);
        align-items: start;
      }

      .why-copy {
        position: sticky;
        top: 106px;
      }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
      }

      .stat-card {
        min-height: 255px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 24px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
      }

      .stat-card h3 {
        margin-bottom: 10px;
      }

      .stat-card p {
        color: var(--muted);
        line-height: 1.6;
      }

      .stat-value {
        color: var(--accent);
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(3.4rem, 8vw, 6rem);
        line-height: 0.9;
      }

      .bar-list {
        display: grid;
        gap: 10px;
      }

      .bar {
        display: grid;
        grid-template-columns: 78px 1fr 46px;
        gap: 10px;
        align-items: center;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .bar i {
        display: block;
        height: 10px;
        background: #ead9c3;
        border-radius: 999px;
        overflow: hidden;
      }

      .bar i::before {
        content: "";
        display: block;
        width: var(--w);
        height: 100%;
        background: var(--sage);
      }

      .work-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .work-card {
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
        box-shadow: 0 14px 34px rgba(51, 41, 29, 0.08);
      }

      .work-card img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
      }

      .work-card div {
        padding: 18px;
      }

      .work-card h3 {
        margin-bottom: 8px;
        font-size: 1.16rem;
      }

      .work-card p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .work-card ul {
        display: grid;
        gap: 8px;
        margin: 16px 0 0;
        padding: 0;
        color: var(--muted);
        list-style: none;
        line-height: 1.5;
      }

      .work-card li::before {
        content: "+";
        margin-right: 8px;
        color: var(--accent);
        font-weight: 900;
      }

      .services {
        background: #f4eadb;
      }

      .service-list {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }

      .service {
        min-height: 220px;
        padding: 22px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
      }

      .service-icon {
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        margin-bottom: 22px;
        color: #fff;
        background: var(--sage);
        border-radius: 8px;
        font-weight: 900;
      }

      .service:nth-child(2) .service-icon {
        background: var(--accent);
      }

      .service:nth-child(3) .service-icon {
        background: var(--gold);
      }

      .service h3 {
        margin-bottom: 10px;
      }

      .service p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .process {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(28px, 5vw, 64px);
        align-items: center;
      }

      .process-image {
        min-height: 560px;
        border-radius: 8px;
        background:
          linear-gradient(rgba(19, 16, 13, 0.12), rgba(19, 16, 13, 0.12)),
          url("https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1400&q=82")
            center / cover;
        box-shadow: var(--shadow);
      }

      .steps {
        display: grid;
        gap: 16px;
      }

      .step {
        display: grid;
        grid-template-columns: 46px 1fr;
        gap: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--line);
      }

      .step b {
        display: grid;
        place-items: center;
        width: 42px;
        height: 42px;
        color: #fff;
        background: var(--accent-dark);
        border-radius: 8px;
      }

      .step h3 {
        margin-bottom: 6px;
      }

      .step p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .quote-band {
        color: #fff;
        background: var(--sage);
      }

      .quote {
        display: grid;
        grid-template-columns: 1fr 0.42fr;
        gap: 40px;
        align-items: end;
      }

      .quote blockquote {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2rem, 5vw, 4.25rem);
        line-height: 1.05;
      }

      .quote p {
        margin-bottom: 0;
        color: rgba(255, 255, 255, 0.76);
        line-height: 1.7;
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }

      .price-card {
        display: flex;
        flex-direction: column;
        min-height: 520px;
        padding: 24px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
      }

      .price-card.featured {
        border-color: var(--accent);
        box-shadow: var(--shadow);
      }

      .pill {
        width: fit-content;
        margin-bottom: 18px;
        padding: 7px 10px;
        color: var(--accent-dark);
        background: #f7d8cf;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 850;
        text-transform: uppercase;
      }

      .price {
        margin: 8px 0 16px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.3rem, 5vw, 4rem);
        line-height: 1;
      }

      .price-note {
        margin: -4px 0 18px;
        color: var(--accent-dark);
        font-weight: 850;
      }

      .price-card p,
      .price-card li {
        color: var(--muted);
        line-height: 1.55;
      }

      .price-card ul {
        display: grid;
        gap: 10px;
        margin: 18px 0 24px;
        padding: 0;
        list-style: none;
      }

      .price-card li::before {
        content: "+";
        margin-right: 8px;
        color: var(--accent);
        font-weight: 900;
      }

      .price-card .button {
        margin-top: auto;
      }

      .contact {
        display: grid;
        grid-template-columns: 1fr 0.78fr;
        gap: 28px;
        align-items: stretch;
      }

      .contact-main,
      .contact-side {
        padding: clamp(24px, 4vw, 44px);
        border-radius: 8px;
      }

      .contact-main {
        color: #fff;
        background:
          linear-gradient(120deg, rgba(113, 30, 24, 0.95), rgba(184, 50, 36, 0.78)),
          url("https://images.unsplash.com/photo-1552566626-52f8b828add9?auto=format&fit=crop&w=1400&q=82")
            center / cover;
      }

      .contact-main h2 {
        margin-bottom: 18px;
      }

      .contact-main p {
        max-width: 620px;
        color: rgba(255, 255, 255, 0.86);
        line-height: 1.7;
      }

      .contact-side {
        background: var(--surface);
        border: 1px solid var(--line);
      }

      form {
        display: grid;
        gap: 14px;
        margin-top: 24px;
      }

      .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
      }

      label {
        display: grid;
        gap: 8px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.9rem;
        font-weight: 750;
      }

      input,
      select,
      textarea {
        width: 100%;
        min-height: 48px;
        padding: 12px 13px;
        color: var(--ink);
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 8px;
        font: inherit;
      }

      textarea {
        min-height: 132px;
        resize: vertical;
      }

      .faq {
        display: grid;
        gap: 12px;
      }

      details {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
      }

      summary {
        cursor: pointer;
        padding: 20px;
        font-weight: 850;
      }

      details p {
        margin: 0;
        padding: 0 20px 20px;
        color: var(--muted);
        line-height: 1.7;
      }

      .contact-line {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding: 16px 0;
        border-bottom: 1px solid var(--line);
      }

      .contact-line span {
        color: var(--muted);
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 26px clamp(18px, 5vw, 64px);
        color: var(--muted);
        border-top: 1px solid var(--line);
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(184, 50, 36, 0.045) 1px, transparent 1px),
          linear-gradient(rgba(64, 92, 75, 0.045) 1px, transparent 1px);
        background-size: 86px 86px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), transparent 72%);
      }

      .nav-links a {
        position: relative;
        padding: 8px 0;
        transition:
          color 160ms ease,
          transform 160ms ease;
      }

      .nav-links a::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 1px;
        height: 2px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 180ms ease;
      }

      .nav-links a:hover::after {
        transform: scaleX(1);
        transform-origin: left;
      }

      .nav-cta,
      .button,
      .work-card,
      .service,
      .price-card,
      .stat-card,
      details {
        -webkit-tap-highlight-color: transparent;
      }

      a:focus-visible,
      .button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible,
      summary:focus-visible {
        outline: 3px solid rgba(245, 197, 102, 0.64);
        outline-offset: 4px;
      }

      .button {
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          background 180ms ease;
      }

      .button:hover,
      .nav-cta:hover {
        box-shadow: 0 16px 34px rgba(24, 22, 20, 0.22);
        transform: translateY(-2px);
      }

      .button.secondary:hover {
        color: #fff;
        background: var(--accent);
        border-color: var(--accent);
      }

      .hero {
        position: relative;
        overflow: hidden;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 130px;
        pointer-events: none;
        background: linear-gradient(to bottom, transparent, var(--paper));
      }

      .hero-grid {
        position: relative;
        z-index: 1;
      }

      .quick-panel,
      .stat-card,
      .work-card,
      .service,
      .price-card,
      details,
      .contact-side {
        position: relative;
        overflow: hidden;
      }

      .quick-panel::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(135deg, rgba(200, 143, 45, 0.18), transparent 38%);
      }

      .metric {
        position: relative;
      }

      .section {
        position: relative;
      }

      .section::before {
        content: "";
        position: absolute;
        left: clamp(18px, 5vw, 64px);
        right: clamp(18px, 5vw, 64px);
        top: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(24, 22, 20, 0.14), transparent);
      }

      .services::before,
      .quote-band::before {
        display: none;
      }

      h1,
      h2 {
        text-wrap: balance;
      }

      .lead,
      .hero-copy,
      .work-card p,
      .service p,
      .price-card p,
      .stat-card p,
      details p {
        text-wrap: pretty;
      }

      .stat-card,
      .work-card,
      .service,
      .price-card,
      details {
        transition:
          transform 200ms ease,
          box-shadow 200ms ease,
          border-color 200ms ease;
      }

      .stat-card:hover,
      .work-card:hover,
      .service:hover,
      .price-card:hover,
      details:hover {
        border-color: rgba(184, 50, 36, 0.38);
        box-shadow: var(--shadow);
        transform: translateY(-5px);
      }

      .work-card img {
        filter: saturate(1.04) contrast(1.02);
        transition:
          transform 520ms ease,
          filter 520ms ease;
      }

      .work-card:hover img {
        filter: saturate(1.12) contrast(1.04);
        transform: scale(1.04);
      }

      .stat-card::after,
      .service::after,
      .price-card::after {
        content: "";
        position: absolute;
        left: 18px;
        right: 18px;
        bottom: 16px;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--sage), var(--gold));
        border-radius: 999px;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 220ms ease;
      }

      .stat-card:hover::after,
      .service:hover::after,
      .price-card:hover::after {
        transform: scaleX(1);
      }

      .price-card.featured {
        transform: translateY(-8px);
      }

      .price-card.featured:hover {
        transform: translateY(-12px);
      }

      .process-image {
        filter: saturate(1.05) contrast(1.03);
      }

      .step {
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .step:hover {
        border-color: rgba(184, 50, 36, 0.42);
        transform: translateX(5px);
      }

      .quote-band {
        position: relative;
        overflow: hidden;
      }

      .quote-band::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(120deg, rgba(255, 255, 255, 0.08), transparent 42%);
      }

      .quote {
        position: relative;
        z-index: 1;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: #f5c566;
        box-shadow: 0 0 0 4px rgba(245, 197, 102, 0.18);
        outline: 0;
      }

      summary {
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      summary::after {
        content: "+";
        float: right;
        color: var(--accent);
        font-weight: 900;
      }

      details[open] summary::after {
        content: "-";
      }

      .brand-mark {
        animation: markPulse 5s ease-in-out infinite;
      }

      .brand {
        animation: navDrop 720ms ease both;
      }

      .hero h1 {
        animation: portfolioHeroTitle 900ms cubic-bezier(0.18, 0.88, 0.32, 1.08) both;
      }

      .hero-copy {
        animation: portfolioFadeUp 900ms 160ms ease both;
      }

      .hero-actions {
        animation: portfolioFadeUp 900ms 300ms ease both;
      }

      .quick-panel {
        animation: panelFloat 6.5s ease-in-out infinite;
      }

      .metric strong,
      .stat-value {
        animation: warmGlow 4.5s ease-in-out infinite;
      }

      .button {
        position: relative;
        overflow: hidden;
      }

      .button::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(110deg, transparent 0 35%, rgba(255, 255, 255, 0.35) 48%, transparent 62% 100%);
