      .work-card:hover h3,
      .service:hover h3,
      .price-card:hover h3,
      .step:hover h3 {
        animation: textNudge 330ms ease;
      }

      .process-image {
        animation: slowImagePan 14s ease-in-out infinite alternate;
      }

      .quote blockquote {
        animation: quoteSettle 900ms ease both;
      }

      @keyframes markPulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(184, 50, 36, 0);
          transform: rotate(0deg);
        }

        50% {
          box-shadow: 0 0 0 8px rgba(184, 50, 36, 0.15);
          transform: rotate(-4deg);
        }
      }

      @keyframes navDrop {
        from {
          opacity: 0;
          transform: translateY(-12px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes portfolioHeroTitle {
        from {
          opacity: 0;
          transform: translateY(28px) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes portfolioFadeUp {
        from {
          opacity: 0;
          transform: translateY(18px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes panelFloat {
        0%,
        100% {
          transform: translateY(0);
        }

        50% {
          transform: translateY(-10px);
        }
      }

      @keyframes warmGlow {
        0%,
        100% {
          text-shadow: 0 0 0 rgba(184, 50, 36, 0);
        }

        50% {
          text-shadow: 0 0 18px rgba(184, 50, 36, 0.28);
        }
      }

      @keyframes cardRise {
        from {
          opacity: 0;
          transform: translateY(16px) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes textNudge {
        0%,
        100% {
          transform: translateX(0);
        }

        45% {
          transform: translateX(5px);
        }
      }

      @keyframes slowImagePan {
        from {
          background-position: center;
        }

        to {
          background-position: center 44%;
        }
      }

      @keyframes quoteSettle {
        from {
          opacity: 0;
          transform: translateY(18px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 980px) {
        .hero-grid,
        .section-head,
        .process,
        .quote,
        .contact {
